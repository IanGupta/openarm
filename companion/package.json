{
  "name": "openarm",
  "version": "1.0.0",
  "private": true,
  "author": "OpenClaw Labs",
  "description": "OpenArm Windows app for OpenClaw Hub and Arm roles",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build:win": "electron-builder --win nsis && npm run build:uninstaller",
    "build:mac": "electron-builder --mac dmg zip",
    "build:portable": "electron-builder --win portable",
    "build:uninstaller": "node ./scripts/build-uninstaller-launcher.mjs",
    "build:linux": "electron-builder --linux AppImage tar.gz"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "34.5.8",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.openclaw.openarm",
    "productName": "OpenArm",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "OpenArm-Setup-${version}.${ext}",
      "icon": "build/openarm.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "OpenArm-${version}-mac-${arch}.${ext}",
      "icon": "build/openarm.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "build/installer-role.nsh",
      "installerIcon": "build/openarm.ico",
      "uninstallerIcon": "build/openarm.ico",
      "installerHeaderIcon": "build/openarm.ico"
    },
    "electronVersion": "34.5.8",
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility",
      "artifactName": "OpenArm-${version}-${arch}.${ext}",
      "icon": "build/icons"
    }
  }
}
